{
  "name": "autotranslate",
  "version": "0.0.0",
  "private": true,
  "description": "Automated, AI-powered i18n for any React framework. Code is the source of truth.",
  "license": "MIT",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "homepage": "https://github.com/tamimbinhakim/autotranslate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/autotranslate.git"
  },
  "bugs": {
    "url": "https://github.com/tamimbinhakim/autotranslate/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:ci": "turbo run test -- --run --passWithNoTests",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write . && prettier --write \"**/*.{md,yml,yaml,json}\" --ignore-path .prettierignore",
    "format:check": "biome format . && prettier --check \"**/*.{md,yml,yaml,json}\" --ignore-path .prettierignore",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only",
    "release": "turbo run build --filter=./packages/* && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "turbo": "^2.10.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
