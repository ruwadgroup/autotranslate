{
  "name": "@autotranslate/cli",
  "version": "0.0.0",
  "description": "autotranslate CLI: extract, translate, watch, check.",
  "license": "MIT",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/autotranslate.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/tamimbinhakim/autotranslate/tree/main/packages/cli#readme",
  "bugs": "https://github.com/tamimbinhakim/autotranslate/issues",
  "keywords": [
    "i18n",
    "cli",
    "translation",
    "ai",
    "extract"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "autotranslate": "./dist/cli.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:ci": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@autotranslate/core": "workspace:*",
    "@autotranslate/providers": "workspace:*",
    "commander": "^14.0.3",
    "chalk": "^5.4.1",
    "ora": "^8.1.1",
    "cli-progress": "^3.12.0",
    "@babel/parser": "^7.26.3",
    "@babel/traverse": "^7.26.4",
    "@babel/types": "^7.26.3",
    "fast-glob": "^3.3.3",
    "jiti": "^2.4.2"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
