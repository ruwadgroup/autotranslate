{
  "name": "@autotranslate/cli",
  "version": "1.0.0-beta.2",
  "description": "autotranslate CLI: extract, translate, watch, check.",
  "license": "MIT",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/autotranslate.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/tamimbinhakim/autotranslate/tree/main/packages/cli#readme",
  "bugs": "https://github.com/tamimbinhakim/autotranslate/issues",
  "keywords": [
    "i18n",
    "cli",
    "translation",
    "ai",
    "extract"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "autotranslate": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./transform": {
      "types": "./dist/transform.d.ts",
      "import": {
        "types": "./dist/transform.d.ts",
        "default": "./dist/transform.js"
      },
      "require": {
        "types": "./dist/transform.d.cts",
        "default": "./dist/transform.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:ci": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@autotranslate/core": "workspace:*",
    "@autotranslate/providers": "workspace:*",
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "jiti": "^2.7.0",
    "ora": "^9.4.1"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
