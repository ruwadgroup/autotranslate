{
  "name": "@autotranslate/zod",
  "version": "0.1.0",
  "description": "Zod v4 error map: translates standard Zod issues through your autotranslate catalog.",
  "license": "MIT",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/autotranslate.git",
    "directory": "packages/zod"
  },
  "homepage": "https://github.com/tamimbinhakim/autotranslate/tree/main/packages/zod#readme",
  "bugs": "https://github.com/tamimbinhakim/autotranslate/issues",
  "keywords": [
    "i18n",
    "zod",
    "validation",
    "translation",
    "error-map"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./source": {
      "types": "./dist/source.d.ts",
      "import": "./dist/source.js",
      "require": "./dist/source.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    },
    "./remix": {
      "types": "./dist/remix.d.ts",
      "import": "./dist/remix.js",
      "require": "./dist/remix.cjs"
    },
    "./catalog/*": "./dist/catalog/*.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:ci": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@autotranslate/core": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "zod": ">=4.0.0 <5.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@autotranslate/next": "workspace:*",
    "@types/node": "^25.6.0",
    "next": "^16.2.4",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
