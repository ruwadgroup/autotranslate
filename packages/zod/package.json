{
  "name": "@autotranslate/zod",
  "version": "1.0.0-beta.7",
  "description": "Zod v4 error map: translates standard Zod issues through your autotranslate catalog.",
  "license": "MIT",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ruwadgroup/autotranslate.git",
    "directory": "packages/zod"
  },
  "homepage": "https://github.com/ruwadgroup/autotranslate/tree/main/packages/zod#readme",
  "bugs": "https://github.com/ruwadgroup/autotranslate/issues",
  "keywords": [
    "i18n",
    "zod",
    "validation",
    "translation",
    "error-map"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./source": {
      "import": {
        "types": "./dist/source.d.ts",
        "default": "./dist/source.js"
      },
      "require": {
        "types": "./dist/source.d.cts",
        "default": "./dist/source.cjs"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/next.d.ts",
        "default": "./dist/next.js"
      },
      "require": {
        "types": "./dist/next.d.cts",
        "default": "./dist/next.cjs"
      }
    },
    "./remix": {
      "import": {
        "types": "./dist/remix.d.ts",
        "default": "./dist/remix.js"
      },
      "require": {
        "types": "./dist/remix.d.cts",
        "default": "./dist/remix.cjs"
      }
    },
    "./catalog/*": "./dist/catalog/*.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:ci": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@autotranslate/core": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "zod": ">=4.0.0 <5.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@autotranslate/next": "workspace:*",
    "@types/node": "^26.1.0",
    "next": "^16.2.10",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "typesVersions": {
    "*": {
      "source": [
        "./dist/source.d.ts"
      ],
      "next": [
        "./dist/next.d.ts"
      ],
      "remix": [
        "./dist/remix.d.ts"
      ]
    }
  }
}
