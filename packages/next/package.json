{
  "name": "@autotranslate/next",
  "version": "1.0.0-beta.8",
  "description": "Next.js plugin, middleware, and server helpers for autotranslate.",
  "license": "MIT",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ruwadgroup/autotranslate.git",
    "directory": "packages/next"
  },
  "homepage": "https://github.com/ruwadgroup/autotranslate/tree/main/packages/next#readme",
  "bugs": "https://github.com/ruwadgroup/autotranslate/issues",
  "keywords": [
    "i18n",
    "next.js",
    "translation",
    "ai",
    "rsc",
    "middleware"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./plugin": {
      "import": {
        "types": "./dist/plugin.d.ts",
        "default": "./dist/plugin.js"
      },
      "require": {
        "types": "./dist/plugin.d.cts",
        "default": "./dist/plugin.cjs"
      }
    },
    "./middleware": {
      "import": {
        "types": "./dist/middleware.d.ts",
        "default": "./dist/middleware.js"
      },
      "require": {
        "types": "./dist/middleware.d.cts",
        "default": "./dist/middleware.cjs"
      }
    },
    "./auto-loader": {
      "import": {
        "types": "./dist/auto-loader.d.ts",
        "default": "./dist/auto-loader.js"
      },
      "require": {
        "types": "./dist/auto-loader.d.cts",
        "default": "./dist/auto-loader.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:ci": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@autotranslate/core": "workspace:*",
    "@autotranslate/react": "workspace:*"
  },
  "peerDependencies": {
    "@autotranslate/cli": "workspace:*",
    "@autotranslate/core": "workspace:*",
    "@autotranslate/react": "workspace:*",
    "next": ">=15.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@autotranslate/cli": {
      "optional": true
    }
  },
  "devDependencies": {
    "@autotranslate/cli": "workspace:*",
    "@types/node": "^26.1.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "typesVersions": {
    "*": {
      "plugin": [
        "./dist/plugin.d.ts"
      ],
      "middleware": [
        "./dist/middleware.d.ts"
      ],
      "auto-loader": [
        "./dist/auto-loader.d.ts"
      ]
    }
  }
}
