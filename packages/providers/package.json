{
  "name": "@autotranslate/providers",
  "version": "1.0.0-beta.5",
  "description": "AI & MT translation providers (Vercel AI SDK, DeepL, Google, custom, stub).",
  "license": "MIT",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ruwadgroup/autotranslate.git",
    "directory": "packages/providers"
  },
  "homepage": "https://github.com/ruwadgroup/autotranslate/tree/main/packages/providers#readme",
  "bugs": "https://github.com/ruwadgroup/autotranslate/issues",
  "keywords": [
    "i18n",
    "translation",
    "ai",
    "deepl",
    "google-translate",
    "openai"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./ai": {
      "import": {
        "types": "./dist/ai.d.ts",
        "default": "./dist/ai.js"
      },
      "require": {
        "types": "./dist/ai.d.cts",
        "default": "./dist/ai.cjs"
      }
    },
    "./deepl": {
      "import": {
        "types": "./dist/deepl.d.ts",
        "default": "./dist/deepl.js"
      },
      "require": {
        "types": "./dist/deepl.d.cts",
        "default": "./dist/deepl.cjs"
      }
    },
    "./google": {
      "import": {
        "types": "./dist/google.d.ts",
        "default": "./dist/google.js"
      },
      "require": {
        "types": "./dist/google.d.cts",
        "default": "./dist/google.cjs"
      }
    },
    "./stub": {
      "import": {
        "types": "./dist/stub.d.ts",
        "default": "./dist/stub.js"
      },
      "require": {
        "types": "./dist/stub.d.cts",
        "default": "./dist/stub.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:ci": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@autotranslate/core": "workspace:*",
    "@formatjs/icu-messageformat-parser": "^3.5.12",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": ">=3.0.0 <4.0.0",
    "@ai-sdk/google": ">=3.0.0 <4.0.0",
    "@ai-sdk/openai": ">=3.0.0 <4.0.0",
    "ai": ">=6.0.0 <7.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "ai": "^6.0.218",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "typesVersions": {
    "*": {
      "ai": [
        "./dist/ai.d.ts"
      ],
      "deepl": [
        "./dist/deepl.d.ts"
      ],
      "google": [
        "./dist/google.d.ts"
      ],
      "stub": [
        "./dist/stub.d.ts"
      ]
    }
  }
}
