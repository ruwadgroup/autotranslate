# Copy this file to `.env` and set ONE of the keys below.
#
# Without either set, `pnpm i18n` falls back to the stub-pseudo provider so
# the example still works — but real AI translation requires a real key.
#
# OpenRouter (preferred — one key, many vendors):
#   https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI (fallback):
#   https://platform.openai.com/api-keys
OPENAI_API_KEY=
